// PUBLIC API
// ====
const TableauFilterManager = {
  /**
   * DIFF-BASED SAVE: Only saves filters/parameters that differ from the Initial Dashboard State.
   */
  async saveState(stateName = 'default') {
    Logger.separator();
    Logger.info(`SAVING STATE (DIFF-BASED): "${stateName}"`);
    Logger.separator();

    try {
      const viz = await TableauViz.getViz(CONFIG.VIZ_ID);
      await TableauViz.waitForInteractive(viz);

      // Capture current state
      const currentSnapshot = await FilterCapture.captureState(viz);
    
      // Get initial state for comparison
      const initialState = await InitialStateManager.getInitialState();
    
      // Create diff-based snapshot (only changed items)
      const diffSnapshot = await FilterComparison.createDiffSnapshot(currentSnapshot, initialState);
    
      // Check if there are any changes
      if (diffSnapshot.metadata.totalChangeCount === 0) {
        Logger.warn('No changes from initial dashboard state - nothing to save');
        return { 
          success: false, 
          error: 'No changes from initial dashboard state',
          noChanges: true
        };
      }
    
      const apiResult = await ApiStore.saveState(stateName, diffSnapshot);
      if (!apiResult.success) {
        throw new Error(apiResult.error || 'Failed to save to DB');
      }

      Logger.info(`✓ State "${stateName}" saved successfully (${diffSnapshot.metadata.totalChangeCount} changes)`);
      return { success: true, snapshot: diffSnapshot };

    } catch (error) {
      Logger.error('Save state failed:', error);
      return { success: false, error: error.message };
    }
  },

  /**
   * DIFF-BASED LOAD: Applies the filters/parameters stored in the saved state
   * and resets any leftover filters from a previously applied view back to
   * their initial (baseline) values.
   */
  async loadState(stateName = 'default') {
    Logger.separator();
    Logger.info(`LOADING STATE (DIFF-BASED): "${stateName}"`);
    Logger.separator();

    try {
      const snapshot = ApiStore.loadState(stateName, window.location.href);

      if (!snapshot || typeof snapshot !== 'object') {
        throw new Error(`No saved state found with name: ${stateName}`);
      }

      // Ensure snapshot has the expected shape even if stored data is incomplete
      if (!snapshot.filters)    snapshot.filters    = {};
      if (!snapshot.parameters) snapshot.parameters = {};

      Logger.info('Snapshot loaded from currentBlock.data');
      Logger.debug(`Captured at: ${snapshot.metadata?.capturedAt}`);

      const savedPageUrl = snapshot.metadata?.pageUrl;
      const currentPageUrl = window.location.href;

      if (savedPageUrl && savedPageUrl !== currentPageUrl) {
        Logger.warn('Saved state is from a different page');
      }

      const viz = await TableauViz.getViz(CONFIG.VIZ_ID);
      await TableauViz.waitForInteractive(viz);

      // Build a merged snapshot that includes reset entries for stale filters.
      // This ensures switching views clears filters from the prior view that
      // are not part of the new view.
      const mergedSnapshot = await this._buildMergedSnapshot(viz, snapshot);

      const filterCount = Object.keys(mergedSnapshot.filters || {}).length;
      const paramCount = Object.keys(mergedSnapshot.parameters || {}).length;
      Logger.info(`Applying ${filterCount} filter operations and ${paramCount} parameter operations (including resets)`);

      const results = await FilterRestore.restoreState(viz, mergedSnapshot);
      const success = results && results.success;

      if (success) {
        Logger.info(`✓ State "${stateName}" loaded successfully`);
      } else {
        Logger.warn(`⚠ State "${stateName}" loaded with errors`);
      }

      return { success: !!success, results: results || {}, snapshot };

    } catch (error) {
      Logger.error('Load state failed:', error);
      return { success: false, error: error.message };
    }
  },

  async deleteState(stateName = 'default') {
    Logger.info(`Deleting state: "${stateName}"`);
    const apiResult = await ApiStore.deleteState(stateName);
    if (apiResult.success) {
      Logger.info(`✓ State "${stateName}" deleted successfully`);
      return { success: true };
    } else {
      Logger.error(`Failed to delete state: "${stateName}": ${apiResult.error}`);
      return { success: false, error: apiResult.error };
    }
  },

  listStates() {
    Logger.info('Listing all saved states...');
    const states = ApiStore.listStates(window.location.href);
    Logger.info(`Found ${states.length} saved states`);
    return states;
  },

  navigateAndRestore(stateName = 'default') {
    Logger.info(`Navigate and restore: "${stateName}"`);

    const snapshot = ApiStore.loadState(stateName, window.location.href);

    if (!snapshot) {
      Logger.error(`No saved state found with name: ${stateName}`);
      return { success: false, error: 'State not found' };
    }

    const savedPageUrl = snapshot.metadata?.pageUrl;

    if (!savedPageUrl) {
      Logger.error('No page URL found in saved state');
      return { success: false, error: 'No page URL in state' };
    }

    sessionStorage.setItem('applyFiltersOnLoad', 'true');
    sessionStorage.setItem('tableau_restore_state', stateName);

    Logger.info(`Navigating to: ${savedPageUrl}`);
    window.location.href = savedPageUrl;

    return { success: true, navigating: true };
  },

  /**
   * Build a merged snapshot that combines the new view's filters with reset
   * entries for any filters that are currently changed (vs. initial baseline)
   * but NOT part of the new view. This prevents stale filters from a
   * previously applied view from persisting when switching views.
   */
  async _buildMergedSnapshot(viz, viewSnapshot) {
    if (!viewSnapshot) return viewSnapshot;

    try {
      const initialState = InitialStateManager.getCachedState();
      if (!initialState) {
        Logger.debug('[_buildMergedSnapshot] No initial baseline available — skipping stale filter reset');
        return viewSnapshot;
      }

      // Capture what the dashboard looks like right now
      let currentState;
      try {
        currentState = await FilterCapture.captureState(viz);
      } catch (err) {
        Logger.warn('[_buildMergedSnapshot] Could not capture current state for reset — applying view as-is:', err.message);
        return viewSnapshot;
      }

      if (!currentState) return viewSnapshot;

      const viewFilters    = viewSnapshot.filters    || {};
      const viewParams     = viewSnapshot.parameters || {};
      const initialFilters = initialState.filters    || {};
      const initialParams  = initialState.parameters || {};
      const currentFilters = currentState.filters    || {};
      const currentParams  = currentState.parameters || {};

      // Deep clone the view snapshot so we never mutate the stored data.
      // Filters/parameters contain nested objects (values arrays, min/max)
      // that a shallow Object.assign would share by reference.
      var merged = {};
      try {
        merged.filters    = JSON.parse(JSON.stringify(viewFilters));
        merged.parameters = JSON.parse(JSON.stringify(viewParams));
      } catch (_) {
        Logger.warn('[_buildMergedSnapshot] Deep clone failed — falling back to shallow copy');
        merged.filters    = Object.assign({}, viewFilters);
        merged.parameters = Object.assign({}, viewParams);
      }
      merged.metadata = viewSnapshot.metadata || null;

      var resetCount = 0;

      // For each filter that is currently different from initial and NOT in the
      // new view, inject the initial value so restoreState resets it.
      for (const filterName of Object.keys(currentFilters)) {
        if (merged.filters[filterName]) continue; // new view handles this one

        const currentVal = currentFilters[filterName];
        const initialVal = initialFilters[filterName];

        if (!initialVal) continue; // wasn't in baseline — leave it alone

        try {
          const same = FilterComparison._areFiltersEqual(currentVal, initialVal);
          if (!same) {
            Logger.debug('[_buildMergedSnapshot] Resetting stale filter: ' + filterName);
            merged.filters[filterName] = JSON.parse(JSON.stringify(initialVal));
            resetCount++;
          }
        } catch (cmpErr) {
          // Comparison failed — safer to include the reset than to leave a stale filter
          Logger.warn('[_buildMergedSnapshot] Comparison failed for filter "' + filterName + '", resetting to initial:', cmpErr.message);
          try {
            merged.filters[filterName] = JSON.parse(JSON.stringify(initialVal));
          } catch (_) {
            merged.filters[filterName] = initialVal;
          }
          resetCount++;
        }
      }

      // Same for parameters
      for (const paramName of Object.keys(currentParams)) {
        if (merged.parameters[paramName]) continue;

        const currentVal = currentParams[paramName];
        const initialVal = initialParams[paramName];

        if (!initialVal) continue;

        var currentParamValue = currentVal  && currentVal.value  !== undefined ? currentVal.value  : null;
        var initialParamValue = initialVal  && initialVal.value  !== undefined ? initialVal.value  : null;

        if (currentParamValue !== initialParamValue) {
          Logger.debug('[_buildMergedSnapshot] Resetting stale parameter: ' + paramName);
          try {
            merged.parameters[paramName] = JSON.parse(JSON.stringify(initialVal));
          } catch (_) {
            merged.parameters[paramName] = initialVal;
          }
          resetCount++;
        }
      }

      if (resetCount > 0) {
        Logger.info('[_buildMergedSnapshot] Injected ' + resetCount + ' reset(s) for stale filters/parameters from prior view');
      }

      return merged;

    } catch (error) {
      Logger.error('[_buildMergedSnapshot] Unexpected error — applying view as-is:', error.message);
      return viewSnapshot;
    }
  },

  /**
   * Get the initial dashboard state for reference.
   */
  async getInitialState() {
    return await InitialStateManager.getInitialState();
  },

  /**
   * Reset the initial state (re-captures on next comparison).
   */
  resetInitialState() {
    InitialStateManager.reset();
  },

  /**
   * Marks a saved state as the default for the current page.
   * Clears any previously set default first (both locally and in the DB).
   */
  async setDefaultState(stateName) {
    Logger.info(`Setting default state: "${stateName}"`);
    const pageUrl = window.location.href;
    const apiResult = await ApiStore.setDefault(stateName, pageUrl);
    if (!apiResult.success) {
      Logger.warn(`[TableauFilterManager] DB set default failed: ${apiResult.error}`);
    }
    return { success: apiResult.success };
  },

  /**
   * Removes the default state designation for the current page.
   */
  async clearDefaultState() {
    Logger.info('Clearing default state');
    const pageUrl = window.location.href;
    const apiResult = await ApiStore.clearDefault(pageUrl);
    if (!apiResult.success) {
      Logger.warn(`[TableauFilterManager] DB clear default failed: ${apiResult.error}`);
    }
    return { success: apiResult.success };
  },

  /**
   * Returns the name of the current default state for this page, or null.
   */
  getDefaultState() {
    return ApiStore.getDefault(window.location.href);
  }
};

// ====
// UI CONTROLLER
// ====
const UIController = {
  elements: {},
  currentPreview: null,
  currentDiff: null,  // Stores the current diff comparison result
  _appliedStateName: null,  // Tracks which view is currently active (set on successful apply/restore)

  init() {
    this.elements = {
      floatBtn: document.getElementById('tfmFloatBtn'),
      modalOverlay: document.getElementById('tfmModalOverlay'),
      closeBtn: document.getElementById('tfmCloseBtn'),
      tabs: document.querySelectorAll('.tfm-tab'),
      tabContents: document.querySelectorAll('.tfm-tab-content'),
      stateName: document.getElementById('tfmStateName'),
      saveBtn: document.getElementById('tfmSaveBtn'),
      preview: document.getElementById('tfmPreview'),
      previewContent: document.getElementById('tfmPreviewContent'),
      statesList: document.getElementById('tfmStatesList'),
      savedLoading: document.getElementById('tfmSavedLoading'),
      notification: document.getElementById('tfmNotification'),
      notificationTitle: document.getElementById('tfmNotificationTitle'),
      notificationMessage: document.getElementById('tfmNotificationMessage'),
      notificationProgress: document.getElementById('tfmNotificationProgress'),
      notificationProgressBar: document.getElementById('tfmNotificationProgressBar'),
      notificationDetails: document.getElementById('tfmNotificationDetails'),
      modalNotification: document.getElementById('tfmModalNotification'),
      modalNotificationIcon: document.getElementById('tfmModalNotificationIcon'),
      modalNotificationTitle: document.getElementById('tfmModalNotificationTitle'),
      modalNotificationMessage: document.getElementById('tfmModalNotificationMessage')
    };
    this._busy = false;
    this._appliedStateName = null;

    this._injectStyleOverrides();
    this.bindEvents();
    this.setupProgressListener();
    Logger.info('UI Controller initialized');
  },

  /**
   * Inject CSS overrides for font inheritance and disabled Apply button.
   * Default-card colors live in the external CSS field.
   * Idempotent — safe to call more than once.
   */
  _injectStyleOverrides() {
    if (document.getElementById('tfm-style-overrides')) return;
    try {
      var style = document.createElement('style');
      style.id = 'tfm-style-overrides';
      style.textContent = [
        '.tfm-modal, .tfm-modal *, .tfm-float-btn { font-family: inherit; }',
        '.tfm-btn.tfm-btn-applied { opacity: 0.5; cursor: default; pointer-events: none; }',
      ].join('\n');
      (document.head || document.documentElement).appendChild(style);
    } catch (err) {
      Logger.warn('[UIController] Failed to inject style overrides:', err.message);
    }
  },

  setupProgressListener() {
    ProgressTracker.onProgress((data) => {
      if (CONFIG.SHOW_PROGRESS_UI && this.elements.notificationProgress.classList.contains('active')) {
        this.elements.notificationProgressBar.style.width = `${data.percentage}%`;
        this.elements.notificationMessage.textContent = `${data.percentage}% - ${data.status}`;
        this.elements.notificationDetails.textContent = `${data.current}/${data.total} operations`;
      }
    });
  },

  bindEvents() {
    this.elements.floatBtn.addEventListener('click', () => this.openModal());
    this.elements.closeBtn.addEventListener('click', () => this.closeModal());
    this.elements.modalOverlay.addEventListener('click', (e) => {
      if (e.target === this.elements.modalOverlay) {
        this.closeModal();
      }
    });

    this.elements.tabs.forEach(tab => {
      tab.addEventListener('click', () => this.switchTab(tab.dataset.tab));
    });

    this.elements.stateName.addEventListener('input', (e) => {
      // Enable save button only if there's a name AND there are changes
      const hasName = e.target.value.trim().length > 0;
      const hasChanges = this.currentDiff && this.currentDiff.totalChangeCount > 0;
      this.elements.saveBtn.disabled = !(hasName && hasChanges);
    });

    this.elements.saveBtn.addEventListener('click', () => this.handleSave());

    this.elements.stateName.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && !this.elements.saveBtn.disabled) {
        this.handleSave();
      }
    });
  },

  async openModal() {
    this.elements.modalOverlay.classList.add('active');
    await this.loadPreview();

    const activeTab = document.querySelector('.tfm-tab.active');
    if (activeTab && activeTab.dataset.tab === 'saved') {
      this.loadSavedStates();
    }
  },

  closeModal() {
    this.elements.modalOverlay.classList.remove('active');
    this.elements.stateName.value = '';
    this.elements.saveBtn.disabled = true;
    this.setBusy(false);
    this.hideModalNotification();
  },

  switchTab(tabName) {
    this.elements.tabs.forEach(tab => {
      tab.classList.toggle('active', tab.dataset.tab === tabName);
    });

    this.elements.tabContents.forEach(content => {
      content.classList.toggle('active', content.id === `tfm${tabName.charAt(0).toUpperCase() + tabName.slice(1)}Tab`);
    });

    if (tabName === 'saved') {
      this.loadSavedStates();
    } else if (tabName === 'save') {
      this.loadPreview();
    }
  },

  /**
   * DIFF-BASED PREVIEW: Shows only filters/parameters that differ from Initial Dashboard State.
   */
  async loadPreview() {
    const loadingEl = this.elements.preview.querySelector('.tfm-loading');
    loadingEl.classList.add('active');
    this.elements.previewContent.innerHTML = '';

    try {
      const viz = await TableauViz.getViz(CONFIG.VIZ_ID);
      await TableauViz.waitForInteractive(viz);
    
      // Capture current state
      const currentSnapshot = await FilterCapture.captureState(viz);
      this.currentPreview = currentSnapshot;
    
      // Get initial state and compare
      const initialState = await InitialStateManager.getInitialState();
      const diff = await FilterComparison.compare(currentSnapshot, initialState);
      this.currentDiff = diff;

      // If the initial state was never captured, block saving and show a clear error
      if (diff.initialStateMissing) {
        this.elements.previewContent.innerHTML = `
          <div class="tfm-diff-summary tfm-no-changes">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Initial dashboard state unavailable.</strong><br>
            Please reload the page and wait for the dashboard to fully load before saving.
          </div>`;
        this.elements.saveBtn.disabled = true;
        return;
      }

      // Log the comparison result to verify async flow
      Logger.info('[UIController] loadPreview: Comparison complete', {
        filterChangeCount: diff.filterChangeCount,
        parameterChangeCount: diff.parameterChangeCount,
        totalChangeCount: diff.totalChangeCount
      });
      if (diff.changedFilterNames && diff.changedFilterNames.length) {
        Logger.info('[UIController] Changed filters: ' + diff.changedFilterNames.join(', '));
      }
      if (diff.changedParameterNames && diff.changedParameterNames.length) {
        Logger.info('[UIController] Changed parameters: ' + diff.changedParameterNames.join(', '));
      }

      // Render the diff-based preview
      this.renderDiffPreview(diff, currentSnapshot);

      // Update save button state based on whether there are changes
      const hasName = this.elements.stateName.value.trim().length > 0;
      this.elements.saveBtn.disabled = !(hasName && diff.totalChangeCount > 0);

    } catch (error) {
      Logger.error('Failed to load preview:', error);
      this.elements.previewContent.innerHTML = `
        <div class="tfm-preview-empty">
          <i class="fas fa-exclamation-triangle"></i> Failed to load current state: ${error.message}
        </div>
      `;
    } finally {
      loadingEl.classList.remove('active');
    }
  },

  /**
   * Render the diff-based preview showing only changed items.
   */
  renderDiffPreview(diff, snapshot) {
    let html = '';

    // Log what we received for debugging
    Logger.info('[UIController] renderDiffPreview received:', {
      filterChangeCount: diff?.filterChangeCount,
      parameterChangeCount: diff?.parameterChangeCount,
      totalChangeCount: diff?.totalChangeCount,
      hasChanges: diff?.hasChanges
    });

    // Defensive: warn if expected properties are missing (should not happen now with await fix)
    if (diff && (diff.filterChangeCount === undefined || diff.parameterChangeCount === undefined)) {
      Logger.warn('[UIController] renderDiffPreview: diff object missing expected count properties - this indicates an async timing issue', {
        filterChangeCount: diff.filterChangeCount,
        parameterChangeCount: diff.parameterChangeCount,
        totalChangeCount: diff.totalChangeCount
      });
    }

    // Diff summary banner
    const totalChangeCount = (diff?.filterChangeCount ?? 0) + (diff?.parameterChangeCount ?? 0);
    if (totalChangeCount === 0) {
      html += `
        <div class="tfm-diff-summary tfm-no-changes">
          <i class="fas fa-info-circle"></i>
          <strong>No changes from initial dashboard state.</strong><br>
          Modify some settings, then return here to save your changes.
        </div>
      `;
    } else {
      html += `
        <div class="tfm-diff-summary">
          <i class="fas fa-check-circle"></i>
          <strong>Saving ${totalChangeCount} changed setting${totalChangeCount !== 1 ? 's' : ''}</strong>
          that differ from the initial dashboard state.
        </div>
      `;
    }

    // Show all changed settings (filters + parameters merged), excluding UI-hidden names
    var hiddenFilters = new Set();
    var _hfArr = CONFIG.UI_HIDDEN_FILTERS || [];
    var _hfi = _hfArr.length;
    while (_hfi--) hiddenFilters.add(_hfArr[_hfi].toLowerCase());
    var hiddenParameters = new Set();
    var _hpArr = CONFIG.UI_HIDDEN_PARAMETERS || [];
    var _hpi = _hpArr.length;
    while (_hpi--) hiddenParameters.add(_hpArr[_hpi].toLowerCase());

    // Log raw changed items (before UI-hidden filtering) to identify exact names/types
    var _rawFilterKeys = Object.keys(diff.changedFilters || {});
    var _rawParamKeys = Object.keys(diff.changedParameters || {});
    Logger.info('[Changed Settings] RAW changed filters (' + _rawFilterKeys.length + '): ' + (_rawFilterKeys.join(', ') || '(none)'));
    Logger.info('[Changed Settings] RAW changed parameters (' + _rawParamKeys.length + '): ' + (_rawParamKeys.join(', ') || '(none)'));
    Logger.info('[Changed Settings] UI_HIDDEN_FILTERS: ' + (CONFIG.UI_HIDDEN_FILTERS || []).join(', ') || '(none)');
    Logger.info('[Changed Settings] UI_HIDDEN_PARAMETERS: ' + (CONFIG.UI_HIDDEN_PARAMETERS || []).join(', ') || '(none)');

    const allChangedSettings = [
      ...Object.entries(diff.changedFilters || {})
        .filter(([name]) => !hiddenFilters.has(name.toLowerCase()))
        .map(([name, filter]) => {
          let valueStr = '';
          if (filter.type === 'categorical') {
            if (filter.values === 'ALL') {
              valueStr = '(All)';
            } else {
              valueStr = filter.values.length > 3
                ? `${filter.values.slice(0, 3).join(', ')}... (+${filter.values.length - 3})`
                : filter.values.join(', ');
            }
          } else if (filter.type === 'range') {
            valueStr = `${filter.min ?? 'Null'} to ${filter.max ?? 'Null'}`;
          }
          return { name, valueStr };
        }),
      ...Object.entries(diff.changedParameters || {})
        .filter(([name]) => !hiddenParameters.has(name.toLowerCase()))
        .map(([name, param]) => ({
          name,
          valueStr: param.value
        }))
    ];

    var _visNames = [];
    var _vni = allChangedSettings.length;
    while (_vni--) _visNames.push(allChangedSettings[_vni].name);
    Logger.info('[Changed Settings] VISIBLE in modal (' + allChangedSettings.length + '): ' + (_visNames.join(', ') || '(none)'));

    if (allChangedSettings.length > 0) {
      html += '<div class="tfm-preview-section">';
      html += `<div class="tfm-preview-section-title"><i class="fas fa-sliders-h"></i> Changed Settings (${allChangedSettings.length})</div>`;
      for (const { name, valueStr } of allChangedSettings) {
        html += `<div class="tfm-preview-item tfm-changed"><strong>${name}:</strong> ${valueStr}</div>`;
      }
      html += '</div>';
    }

    if (!html) {
      html = '<div class="tfm-preview-empty">No filters or parameters found</div>';
    }

    this.elements.previewContent.innerHTML = html;
  },

  async handleSave() {
    if (this._busy) return;
    const stateName = this.elements.stateName.value.trim();

    if (!stateName) {
      this.showModalNotification('error', 'Error', 'Please enter a custom view name');
      return;
    }

    if (!this.currentDiff || this.currentDiff.totalChangeCount === 0) {
      this.showModalNotification('warning', 'No Changes', 'No changes from initial dashboard state to save.');
      return;
    }

    this.setBusy(true);
    this.elements.saveBtn.innerHTML = '<i class="fas fa-save"></i> Saving...';
    this.showModalNotification('progress', 'Saving', `Saving "${stateName}"…`, false);

    try {
      const result = await TableauFilterManager.saveState(stateName);

      if (result.success) {
        const filterCount = result.snapshot.metadata?.filterChangeCount ?? 0;
        const paramCount = result.snapshot.metadata?.parameterChangeCount ?? 0;
        const totalSaved = filterCount + paramCount;
        this.showModalNotification('success', 'Saved',
          `"${stateName}" saved with ${totalSaved} changed setting${totalSaved !== 1 ? 's' : ''}`
        );
        this.elements.stateName.value = '';
        setTimeout(() => { this.switchTab('saved'); }, 1000);
      } else if (result.noChanges) {
        this.showModalNotification('warning', 'No Changes', 'No changes from initial dashboard state to save.');
      } else {
        throw new Error(result.error || 'Failed to save state');
      }

    } catch (error) {
      Logger.error('Save failed:', error);
      this.showModalNotification('error', 'Error', error.message);
    } finally {
      this.setBusy(false);
      this.elements.saveBtn.innerHTML = '<i class="fas fa-save"></i> Save View';
      const hasName = this.elements.stateName.value.trim().length > 0;
      const hasChanges = this.currentDiff && this.currentDiff.totalChangeCount > 0;
      this.elements.saveBtn.disabled = !(hasName && hasChanges);
    }
  },

  async loadSavedStates() {
    this.elements.savedLoading.classList.add('active');
    this.elements.statesList.innerHTML = '';

    try {
      const states = TableauFilterManager.listStates();

      if (states.length === 0) {
        this.elements.statesList.innerHTML = `
          <div class="tfm-empty-state">
            <div class="tfm-empty-icon"><i class="fas fa-inbox"></i></div>
            <div class="tfm-empty-text">No saved custom views yet</div>
            <div class="tfm-empty-subtext">Go to "Save Current View" tab to save your first custom view</div>
          </div>
        `;
      } else {
        const currentDefault = TableauFilterManager.getDefaultState();

        // Sort: default view pinned to top, rest by descending date saved.
        // Missing dates sort to the bottom (after all dated entries).
        var sorted = states.slice().sort(function(a, b) {
          var aDefault = a.name === currentDefault ? 1 : 0;
          var bDefault = b.name === currentDefault ? 1 : 0;
          if (aDefault !== bDefault) return bDefault - aDefault;
          var aDate = (a.snapshot && a.snapshot.metadata && a.snapshot.metadata.capturedAt) || '';
          var bDate = (b.snapshot && b.snapshot.metadata && b.snapshot.metadata.capturedAt) || '';
          if (!aDate && !bDate) return 0;
          if (!aDate) return 1;   // a has no date → push to bottom
          if (!bDate) return -1;  // b has no date → push to bottom
          return bDate > aDate ? 1 : bDate < aDate ? -1 : 0;
        });

        sorted.forEach(state => {
          this.renderStateCard(state, currentDefault);
        });
      }

    } catch (error) {
      Logger.error('Failed to load saved states:', error);
      this.elements.statesList.innerHTML = `
        <div class="tfm-empty-state">
          <div class="tfm-empty-icon"><i class="fas fa-exclamation-triangle"></i></div>
          <div class="tfm-empty-text">Failed to load saved states</div>
          <div class="tfm-empty-subtext">${error.message}</div>
        </div>
      `;
    } finally {
      this.elements.savedLoading.classList.remove('active');
    }
  },

  /**
   * Render a state card showing what the saved state will change.
   */
  renderStateCard(state, currentDefault) {
    if (!state) return;
    const { name, snapshot } = state;

    if (!snapshot || !name) return;

    const isDefault = name === currentDefault;
    const filterCount = Object.keys(snapshot.filters || {}).length;
    const paramCount = Object.keys(snapshot.parameters || {}).length;
    const savedDate = snapshot.metadata?.capturedAt
      ? new Date(snapshot.metadata.capturedAt).toLocaleString(undefined, {
          year: 'numeric', month: 'numeric', day: 'numeric',
          hour: '2-digit', minute: '2-digit'
        })
      : 'Unknown';

    const currentPageUrl = window.location.href;
    const savedPageUrl = snapshot.metadata?.pageUrl;
    const isDifferentPage = savedPageUrl && savedPageUrl !== currentPageUrl;

    const card = document.createElement('div');
    card.className = `tfm-state-card${isDefault ? ' tfm-state-card-default' : ''}`;

    // Build merged settings list (filters + parameters), excluding UI-hidden names.
    // Use pipe-delimited strings for lookup to avoid while-loop subscripts that
    // confuse the no-extension JSX parser.
    var _scHFStr = '|' + (CONFIG.UI_HIDDEN_FILTERS || []).join('|').toLowerCase() + '|';
    var _scHPStr = '|' + (CONFIG.UI_HIDDEN_PARAMETERS || []).join('|').toLowerCase() + '|';

    const allSettings = [
      ...Object.entries(snapshot.filters || {})
        .filter(([name]) => _scHFStr.indexOf('|' + name.toLowerCase() + '|') === -1)
        .map(([name, filter]) => {
          let valueStr = '';
          if (filter.type === 'categorical') {
            valueStr = filter.values === 'ALL' ? '(All)' : (filter.values.length > 3
              ? `${filter.values.slice(0, 3).join(', ')}... (+${filter.values.length - 3})`
              : filter.values.join(', '));
          } else if (filter.type === 'range') {
            valueStr = `${filter.min ?? 'Null'} to ${filter.max ?? 'Null'}`;
          }
          return { name, valueStr };
        }),
      ...Object.entries(snapshot.parameters || {})
        .filter(([name]) => _scHPStr.indexOf('|' + name.toLowerCase() + '|') === -1)
        .map(([name, param]) => ({
          name,
          valueStr: param.value
        }))
    ];
    const totalSettings = allSettings.length;
    const displaySettings = allSettings.slice(0, 5);
    const overflow = totalSettings - displaySettings.length;

    let settingsHtml = displaySettings.map(s =>
      `<div class="tfm-preview-item tfm-changed"><strong>${s.name}:</strong> ${s.valueStr}</div>`
    ).join('');
    if (overflow > 0) {
      settingsHtml += `<div class="tfm-preview-item" style="color:#999;font-style:italic">+${overflow} more setting${overflow !== 1 ? 's' : ''}</div>`;
    }

    let html = `
      <div class="tfm-state-header">
        <div>
          <h3 class="tfm-state-name">
            ${name}
            ${isDefault ? '<span class="tfm-default-badge"><i class="fas fa-star"></i> Default</span>' : ''}
          </h3>
          <div class="tfm-state-meta">Saved: ${savedDate}</div>
        </div>
      </div>

      <div class="tfm-preview-section" style="margin-bottom:12px">
        <div class="tfm-preview-section-title"><i class="fas fa-sliders-h"></i> Changed Settings (${totalSettings})</div>
        ${settingsHtml || '<div class="tfm-preview-empty">No changes recorded</div>'}
      </div>
    `;

    if (snapshot.metadata?.user) {
      html += `
        <div class="tfm-state-info">
          <div class="tfm-state-info-item">
            <i class="fas fa-user"></i> ${snapshot.metadata.user.fullname}
          </div>
        </div>
      `;
    }

    if (isDifferentPage) {
      html += `
        <div class="tfm-state-warning">
          <i class="fas fa-exclamation-triangle"></i> This state was saved from a different page
        </div>
      `;
    }

    const isApplied = this._appliedStateName === name;

    html += '<div class="tfm-state-actions">';

    if (!isDifferentPage) {
      if (isApplied) {
        html += `
          <button class="tfm-btn tfm-btn-primary tfm-btn-small tfm-btn-applied" disabled>
            <i class="fas fa-check"></i> Applied
          </button>
        `;
      } else {
        html += `
          <button class="tfm-btn tfm-btn-primary tfm-btn-small" onclick="UIController.applyState('${name}')">
            <i class="fas fa-check"></i> Apply View
          </button>
        `;
      }
    } else {
      html += `
        <button class="tfm-btn tfm-btn-primary tfm-btn-small" onclick="UIController.navigateAndApply('${name}')">
          <i class="fas fa-external-link-alt"></i> Go to Page & Apply
        </button>
      `;
    }

    if (isDefault) {
      html += `
        <button class="tfm-btn tfm-btn-default-active tfm-btn-small" onclick="UIController.clearDefaultState()">
          <i class="fas fa-star"></i> Remove Default
        </button>
      `;
    } else {
      html += `
        <button class="tfm-btn tfm-btn-default tfm-btn-small" onclick="UIController.setDefaultState('${name}')">
          <i class="far fa-star"></i> Set as Default
        </button>
      `;
    }

    html += `
      <button class="tfm-btn tfm-btn-danger tfm-btn-small" onclick="UIController.deleteState('${name}')">
        <i class="fas fa-trash-alt"></i> Delete
      </button>
    `;

    html += '</div>';

    card.innerHTML = html;
    this.elements.statesList.appendChild(card);
  },

  async applyState(stateName) {
    if (this._busy) return;
    this.setBusy(true);
    this.showModalNotification('progress', 'Applying', `Applying "${stateName}"…`, false);

    try {
      const result = await TableauFilterManager.loadState(stateName);

      if (result && result.success) {
        this._appliedStateName = stateName;
        const stats = result.results || {};
        var fApplied = stats.filtersApplied    || 0;
        var pApplied = stats.parametersApplied || 0;
        var skipped  = (stats.filtersSkipped   || 0) + (stats.parametersSkipped || 0);
        this.showModalNotification('success', 'Applied',
          fApplied + ' filter' + (fApplied !== 1 ? 's' : '') + ', ' +
          pApplied + ' parameter' + (pApplied !== 1 ? 's' : '') +
          (skipped > 0 ? ' (' + skipped + ' already matched)' : '')
        );
        this.loadSavedStates(); // refresh cards so the applied button grays out
        setTimeout(() => { this.closeModal(); }, 1200);
      } else {
        throw new Error((result && result.error) || 'Failed to apply state');
      }

    } catch (error) {
      Logger.error('Apply failed:', error);
      this.showModalNotification('error', 'Error', error.message || 'Unknown error');
    } finally {
      this.setBusy(false);
    }
  },

  navigateAndApply(stateName) {
    TableauFilterManager.navigateAndRestore(stateName);
  },

  viewState(stateName) {
    const snapshot = ApiStore.loadState(stateName, window.location.href);
    if (snapshot) {
      console.log(`=== STATE: ${stateName} (DIFF-BASED) ===`);
      console.log('Changed Filters:', Object.keys(snapshot.filters || {}));
      console.log('Changed Parameters:', Object.keys(snapshot.parameters || {}));
      console.log('Full snapshot:', JSON.stringify(snapshot, null, 2));
      this.showNotification('success', 'View State', 'State details logged to console (F12)');
    }
  },

  async setDefaultState(stateName) {
    if (this._busy) return;
    this.setBusy(true);
    this.showModalNotification('progress', 'Saving', 'Updating default…', false);
    try {
      await TableauFilterManager.setDefaultState(stateName);
      this.showModalNotification('success', 'Default Set', `"${stateName}" will auto-load on this page`);
      this.loadSavedStates();
    } catch (error) {
      this.showModalNotification('error', 'Error', error.message);
    } finally {
      this.setBusy(false);
    }
  },

  async clearDefaultState() {
    if (this._busy) return;
    this.setBusy(true);
    this.showModalNotification('progress', 'Saving', 'Removing default…', false);
    try {
      await TableauFilterManager.clearDefaultState();
      this.showModalNotification('success', 'Default Removed', 'No state will auto-load on this page');
      this.loadSavedStates();
    } catch (error) {
      this.showModalNotification('error', 'Error', error.message);
    } finally {
      this.setBusy(false);
    }
  },

  async deleteState(stateName) {
    if (this._busy) return;
    if (!confirm(`Are you sure you want to delete the custom view "${stateName}"?`)) {
      return;
    }

    this.setBusy(true);
    this.showModalNotification('progress', 'Deleting', `Deleting "${stateName}"…`, false);

    try {
      const currentDefault = TableauFilterManager.getDefaultState();
      if (currentDefault === stateName) {
        await TableauFilterManager.clearDefaultState();
      }

      const result = await TableauFilterManager.deleteState(stateName);

      if (result && result.success) {
        if (this._appliedStateName === stateName) {
          this._appliedStateName = null;
        }
        this.showModalNotification('success', 'Deleted', `"${stateName}" deleted successfully`);
        this.loadSavedStates();
      } else {
        this.showModalNotification('error', 'Error', 'Failed to delete state');
      }
    } catch (error) {
      this.showModalNotification('error', 'Error', error.message);
    } finally {
      this.setBusy(false);
    }
  },

  showModalNotification(type, title, message, autoHide = true) {
    const icons = {
      success:  'fa-solid fa-check',
      error:    'fa-solid fa-xmark',
      warning:  'fa-solid fa-triangle-exclamation',
      progress: 'fa-solid fa-spinner fa-spin'
    };
    const el = this.elements.modalNotification;
    el.className = `tfm-modal-notification ${type} active`;
    this.elements.modalNotificationIcon.className = icons[type] || icons.success;
    this.elements.modalNotificationTitle.textContent = title ? title + ' — ' : '';
    this.elements.modalNotificationMessage.textContent = message;
    if (this._modalNotifTimer) clearTimeout(this._modalNotifTimer);
    if (autoHide && type !== 'progress') {
      this._modalNotifTimer = setTimeout(() => { el.classList.remove('active'); }, 3500);
    }
  },

  hideModalNotification() {
    if (this._modalNotifTimer) clearTimeout(this._modalNotifTimer);
    this.elements.modalNotification.classList.remove('active');
  },

  setBusy(busy) {
    this._busy = busy;
    // Grey out / restore card buttons
    this.elements.statesList.classList.toggle('tfm-states-busy', busy);
    // Disable / restore tabs
    this.elements.tabs.forEach(tab => tab.classList.toggle('tfm-tab-disabled', busy));
    // Save button is handled per-action, but keep it disabled while busy
    if (busy) this.elements.saveBtn.disabled = true;
  },

  showNotification(type, title, message) {
    this.elements.notification.className = `tfm-notification ${type} active`;
    this.elements.notificationTitle.textContent = title;
    this.elements.notificationMessage.textContent = message;
    this.elements.notificationProgress.classList.remove('active');
    this.elements.notificationDetails.textContent = '';

    const icons = {
      success:  '<i class="fa-solid fa-check"></i>',
      error:    '<i class="fa-solid fa-xmark"></i>',
      warning:  '<i class="fa-solid fa-triangle-exclamation"></i>',
      progress: '<i class="fa-solid fa-spinner fa-spin"></i>'
    };
    this.elements.notification.querySelector('.tfm-notification-icon').innerHTML = icons[type] || icons.success;

    if (type !== 'warning' && type !== 'progress') {
      setTimeout(() => {
        this.elements.notification.classList.remove('active');
      }, 3000);
    }
  },

  showProgressNotification(title, message) {
    this.elements.notification.className = 'tfm-notification progress active';
    this.elements.notificationTitle.textContent = title;
    this.elements.notificationMessage.textContent = message;
    this.elements.notification.querySelector('.tfm-notification-icon').innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
    this.elements.notificationProgress.classList.add('active');
    this.elements.notificationProgressBar.style.width = '0%';
    this.elements.notificationDetails.textContent = 'Starting...';
  },

  hideProgressNotification() {
    this.elements.notificationProgress.classList.remove('active');
  }
};

// ====
// AUTO-RESTORE ON PAGE LOAD
// Order: session flag → favorite flag → normal load
// ====
async function autoRestoreOnLoad() {
  Logger.info('Auto-restore: Checking for states to apply...');

  // STEP 1: Wait for Tableau viz to be interactive ONCE.
  // We keep a reference to `viz` and pass it directly to the restore calls
  // below so we never call getViz() / waitForInteractive() a second time.
  // Doing so risks awaiting onFirstInteractive after it has already fired,
  // which (depending on the Tableau API version) may never resolve again
  // and would silently hang until the 30-second timeout.
  let viz;
  try {
    Logger.info('Auto-restore: Waiting for Tableau viz to be interactive...');
    viz = await TableauViz.getViz(CONFIG.VIZ_ID);
    await TableauViz.waitForInteractive(viz);
    Logger.info('Auto-restore: Viz is interactive, proceeding with state checks');
  } catch (error) {
    Logger.error('Auto-restore: Failed to get interactive viz:', error);
    InitialStateManager._lockBaseline(); // Lock even on failure so getInitialState() doesn't retry
    return;
  }

  // STEP 1b: Ensure the initial (unfiltered) baseline state is captured BEFORE
  // any defaults are applied. If the capture at page-load already succeeded,
  // this is a no-op. If it failed (workbook wasn't ready right after
  // onFirstInteractive), we retry NOW while the viz is fully stable.
  if (!InitialStateManager.hasInitialState()) {
    Logger.info('Auto-restore: Initial state not yet captured — retrying before applying defaults...');
    await InitialStateManager.captureInitialState();
    if (InitialStateManager.hasInitialState()) {
      Logger.info('Auto-restore: Initial state captured on retry.');
    } else {
      Logger.warn('Auto-restore: Initial state capture retry failed — diff comparison will be unavailable.');
    }
  }

  // Peek at session/default flags now so the lock decision can account for them.
  // Session items are only removed later, when they are actually applied.
  const shouldApplyFilters = sessionStorage.getItem('applyFiltersOnLoad') === 'true';
  const restoreStateName = sessionStorage.getItem('tableau_restore_state');
  const currentPageUrl = window.location.href;
  const defaultStateName = ApiStore.getDefault(currentPageUrl);

  // Conditionally lock the baseline before any default filters are applied.
  // - If initial state was captured: always lock so nothing overwrites it.
  // - If initial state is null but defaults WILL be applied: lock anyway —
  //   applying defaults changes the viz, so a post-default lazy capture would
  //   give a wrong baseline.
  // - If initial state is null AND no defaults will be applied: leave unlocked
  //   so loadPreview() can do a lazy capture before the user changes anything.
  const willApplyDefault = (shouldApplyFilters && !!restoreStateName) || !!defaultStateName;
  if (InitialStateManager.hasInitialState() || willApplyDefault) {
    InitialStateManager._lockBaseline();
  }

  // STEP 2: Check for session flag first (highest priority)

  if (shouldApplyFilters && restoreStateName) {
    Logger.info(`Auto-restore: Session flag found - applying state "${restoreStateName}"`);

    sessionStorage.removeItem('applyFiltersOnLoad');
    sessionStorage.removeItem('tableau_restore_state');

    UIController.showProgressNotification('Auto-Restoring', `Applying state "${restoreStateName}"...`);

    try {
      const snapshot = ApiStore.loadState(restoreStateName, currentPageUrl);
      if (!snapshot) throw new Error(`No saved state found: ${restoreStateName}`);
      // Use the already-verified viz directly — no redundant interactive check.
      const results = await FilterRestore.restoreState(viz, snapshot);
      UIController.hideProgressNotification();
      if (results && results.success) {
        UIController._appliedStateName = restoreStateName;
        UIController.showNotification('success', 'Auto-Restored', `State "${restoreStateName}" has been restored`);
      } else {
        var errMsg = (results && results.errors && results.errors[0]) || 'Unknown error';
        UIController.showNotification('error', 'Auto-Restore Failed', errMsg);
      }
    } catch (error) {
      UIController.hideProgressNotification();
      UIController.showNotification('error', 'Auto-Restore Failed', error.message || 'Unknown error');
    }
    return; // Exit after applying session state
  }

  // STEP 3: Check for a user-designated default saved filter
  if (defaultStateName) {
    Logger.info(`Auto-restore: Default state found - applying "${defaultStateName}"`);

    const snapshot = ApiStore.loadState(defaultStateName, currentPageUrl);
    if (snapshot) {
      UIController.showProgressNotification('Loading Default State', `Applying "${defaultStateName}"...`);

      try {
        // Use the already-verified viz directly — no redundant interactive check.
        const results = await FilterRestore.restoreState(viz, snapshot);
        UIController.hideProgressNotification();
        if (results && results.success) {
          UIController._appliedStateName = defaultStateName;
          UIController.showNotification('success', 'Default Loaded', `Default state "${defaultStateName}" has been applied`);
        } else {
          var errMsg = (results && results.errors && results.errors[0]) || 'Unknown error';
          UIController.showNotification('error', 'Default Load Failed', errMsg);
        }
      } catch (error) {
        UIController.hideProgressNotification();
        UIController.showNotification('error', 'Default Load Failed', error.message || 'Unknown error');
      }
      return;
    } else {
      // State was deleted without clearing the default – clean up the stale reference
      Logger.warn(`Auto-restore: Default state "${defaultStateName}" not found in currentBlock.data – clearing stale reference`);
      await ApiStore.clearDefault(currentPageUrl);
    }
  }

  // STEP 4: Normal load (no session flag, no default state)
  Logger.info('Auto-restore: No session flag or default state found - loading dashboard normally');
}

// ====
// EXPOSE TO WINDOW
// ====
window.TableauFilterManager = TableauFilterManager;
window.UIController = UIController;
window.TFM_CONFIG = CONFIG;
window.FilterComparison = FilterComparison;
window.InitialStateManager = InitialStateManager;
window.ApiStore = ApiStore;

// ====
// INITIALIZATION
// ====
(async () => {
  Logger.separator();
  Logger.info('TABLEAU FILTER MANAGER (DIFF-BASED) INITIALIZED');
  Logger.info(`Log Level: ${CONFIG.LOG_LEVEL}`);
  Logger.info(`Debug Mode: ${CONFIG.DEBUG_MODE} (toggle with window.TFM_DEBUG(true/false))`);
  Logger.info(`Batch Size: ${CONFIG.BATCH_SIZE}`);
  Logger.info(`Auto-Restore: ${CONFIG.AUTO_RESTORE_ON_LOAD}`);

  try {
    ZPortalUtil.initializeVizConfig();
    Logger.info(`Active Viz ID: ${CONFIG.VIZ_ID}`);
  } catch (err) {
    Logger.error('Tableau Filter Manager failed to initialize:', err.message);
    alert(`Tableau Filter Manager failed to initialize: ${err.message}`);
    return;
  }
  Logger.separator();

  UIController.init();
  document.getElementById('tfmFloatBtn').removeAttribute('style');

  // Snapshot currentBlock.data immediately while it's in scope and populated
  ApiStore.cacheBlockData();

  // Capture initial dashboard state after a short delay to ensure viz is fully loaded
  Logger.info('Capturing Initial Dashboard State for diff-based comparison...');
  await TableauViz.sleep(2000);
  await InitialStateManager.captureInitialState();
  await InitialStateManager.captureInitialState();
  logInitialStateValues(InitialStateManager.getCachedState());

  await autoRestoreOnLoad();
  Logger.info('Ready to use!');
  Logger.info('Access via: window.TableauFilterManager');
  Logger.info('Enable debug mode: window.TFM_DEBUG(true)');
  Logger.info('View initial state: window.InitialStateManager.getInitialState()');
  Logger.separator();
})();
</script>